{
  "name": "code-review-app-new",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.6.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-code-review-ui": "cds watch --open codereviewui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy northwind.northwindapp --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/code-review-ui"
  ],
  "cds": {
    "requires": {
      "DIM": {
        "kind": "odata-v4",
        "credentials": {
          "destination": "DIM"
        }
      },
      "AgentBuilder": {
        "kind": "odata",
        "credentials": {
          "destination": "AgentBuilder"
        }
      },
      "[production]": {
        "auth": "xsuaa",
        "db": "hana",
        "connectivity": true,
        "destinations": true
      }
    }
  }
}